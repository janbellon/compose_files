USER_UID=1000
USER_GID=1000

GITEA__log__LEVEL=Info
GITEA__log__ENABLE_ACCESS_LOG=true
GITEA__log__ACCESS=console
GITEA__server__ENABLE_REQUEST_LOG="false"

GITEA__log_logger_router__MODE=none
GITEA__log_logger_access__MODE=console

GITEA__database__DB_TYPE=postgres
GITEA__database__HOST=gitea_db:5432
GITEA__database__NAME=gitea
GITEA__database__USER=gitea
GITEA__database__LOG_SQL=false
GITEA__service__DISABLE_REGISTRATION=true

GITEA__server__ROOT_URL=http://gitea.local/
GITEA__server__SSH_DOMAIN=gitea.local
GITEA__server__SSH_PORT=2222

POSTGRES_USER=gitea
POSTGRES_DB=gitea
POSTGRES_PASSWORD=changeme
GITEA__database__PASSWD=${POSTGRES_PASSWORD}
